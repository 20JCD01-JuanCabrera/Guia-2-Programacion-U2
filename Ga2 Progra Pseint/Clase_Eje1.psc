Algoritmo Clase_Eje1
	Escribir "===Días de la semana==="
	
	Definir d Como Entero
	
	Escribir "Digite el número del dia de la semana: "
	Leer d
	
	Segun d Hacer
		1:
			Escribir "Es Lunes"
		2:
			Escribir "Es martes"
		3:
			Escribir "Es miercoles"
		4:
			Escribir "Es jueves"
		5:
			Escribir "Es viernes"
		6: 
			Escribir "Es sabado"
		7:
			Escribir "Es domingo"
		De Otro Modo:
			Escribir "Coloque un numero valido"
	Fin Segun
	
	
FinAlgoritmo
